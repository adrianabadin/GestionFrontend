{
  "name": "regionxfront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cross-env SKIP_INTEGRATION=false vitest run src/__tests__/api.integration.test.ts",
    "test:gantt": "vitest run src/__tests__/gantt",
    "test:gantt:unit": "vitest run src/__tests__/gantt/useGanttTransform.test.ts src/__tests__/gantt/ganttApiSlice.unit.test.ts src/__tests__/gantt/gantt-api.test.ts",
    "test:gantt:components": "vitest run src/__tests__/gantt/GanttItemModal.test.tsx src/__tests__/gantt/GanttChart.integration.test.tsx",
    "test:gantt:e2e": "playwright test e2e/gantt.e2e.spec.ts",
    "test:gantt:coverage": "vitest run --coverage src/__tests__/gantt",
    "test:gantt:watch": "vitest src/__tests__/gantt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.1",
    "@hookform/resolvers": "^3.3.4",
    "@material-tailwind/react": "^2.1.10",
    "@reduxjs/toolkit": "^2.0.1",
    "dhtmlx-gantt": "^9.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "next": "14.1.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.49.3",
    "react-redux": "^9.1.0",
    "react-toastify": "^10.0.4",
    "sharp": "^0.33.5",
    "sweetalert2": "^11.10.7",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dhtmlxgantt": "^6.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "autoprefixer": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "jsdom": "^23.0.0",
    "msw": "^2.12.9",
    "postcss": "^8",
    "tailwind-scrollbar": "^3.0.5",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^1.0.0"
  }
}
